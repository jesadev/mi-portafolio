---
---

<section class="section" id="projects">
  <div class="container">
    <div class="projects__header reveal">
      <p class="section-label">Proyectos</p>
      <h2 class="section-title">
        Trabajo que<br /><em class="text-accent">habla por sí solo</em>
      </h2>
      <p class="projects__sub">
        Proyectos reales que demuestran mis habilidades técnicas y capacidad para resolver problemas.
      </p>
    </div>

    <div class="projects__filters reveal" role="tablist">
      <button class="filter-btn active" data-filter="all">Todos</button>
      <button class="filter-btn" data-filter="frontend">Frontend</button>
      <button class="filter-btn" data-filter="backend">Backend</button>
      <button class="filter-btn" data-filter="ai">IA</button>
      <button class="filter-btn" data-filter="devops">DevOps</button>
    </div>

    <div class="projects__loading" id="projectsLoading">
      <div class="loading-spinner"></div>
    </div>

    <div class="projects__grid" id="projectsGrid"></div>
    <div class="projects__empty hidden" id="projectsEmpty">
      <p>No hay proyectos en esta categoría.</p>
    </div>
  </div>
</section>

<template id="projectCardTemplate">
  <article class="project-card reveal" data-category="">
    <div class="project-card__header">
      <div class="project-card__icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M3 9h18M9 3v18"/>
        </svg>
      </div>
      <div class="project-card__links"></div>
    </div>
    <div class="project-card__body">
      <div class="project-card__meta">
        <span class="project-card__year"></span>
        <span class="project-card__category"></span>
      </div>
      <h3 class="project-card__title"></h3>
      <p class="project-card__desc"></p>
    </div>
    <div class="project-card__footer">
      <div class="project-card__tags"></div>
    </div>
  </article>
</template>

<style>
  .projects__header { max-width: 42rem; margin-bottom: 2.5rem; }
  .projects__sub { color: var(--text-secondary); font-size: 1rem; margin-top: 0.5rem; }
  .projects__filters { display: flex; gap: 0.5rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 0.4rem 1rem;
    border-radius: 99px;
    border: 1px solid var(--border-light);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .filter-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); }
  .filter-btn.active { background: var(--accent); color: var(--text-inverse); border-color: var(--accent); font-weight: 700; }
  .projects__loading { display: flex; justify-content: center; padding: 4rem; }
  .loading-spinner {
    width: 32px; height: 32px;
    border: 2px solid var(--border-light);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  :global(.project-card) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }
  :global(.project-card::before) {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  :global(.project-card:hover) { border-color: var(--border-light); transform: translateY(-6px); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
  :global(.project-card:hover::before) { opacity: 1; }
  :global(.project-card__header) { display: flex; align-items: flex-start; justify-content: space-between; }
  :global(.project-card__icon) {
    width: 44px; height: 44px;
    background: var(--accent-glow);
    border: 1px solid rgba(184,255,53,0.2);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); flex-shrink: 0;
  }
  :global(.project-card__icon svg) { width: 20px; height: 20px; }
  :global(.project-card__links) { display: flex; gap: 0.4rem; }
  :global(.project-link) {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-light);
    color: var(--text-muted);
    transition: all var(--transition-fast);
    text-decoration: none;
  }
  :global(.project-link:hover) { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); transform: translateY(-2px); }
  :global(.project-link svg) { width: 14px; height: 14px; }
  :global(.project-card__meta) { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.4rem; }
  :global(.project-card__year) { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); }
  :global(.project-card__category) {
    font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--accent-dim);
    background: var(--accent-glow); border: 1px solid rgba(184,255,53,0.15);
    padding: 0.15rem 0.5rem; border-radius: 99px;
  }
  :global(.project-card__title) { font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem; line-height: 1.3; }
  :global(.project-card__desc) { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.7; }
  :global(.project-card__footer) { margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--border); }
  :global(.project-card__tags) { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .projects__empty { text-align: center; padding: 4rem; color: var(--text-muted); font-family: var(--font-mono); font-size: 0.85rem; }
  @media (max-width: 480px) { .projects__grid { grid-template-columns: 1fr; } }
</style>

<script>
  interface Project {
    id: number;
    title: string;
    description: string;
    tags: string[];
    category: string;
    github: string | null;
    demo: string | null;
    featured: boolean;
    year: string;
  }

  const CATEGORY_LABELS: Record<string, string> = {
    frontend: 'Frontend', backend: 'Backend',
    ai: 'IA', devops: 'DevOps', fullstack: 'Full Stack',
  };

  const GITHUB_ICON = `<svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`;
  const DEMO_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`;

  function createProjectCard(project: Project): HTMLElement {
    const template = document.getElementById('projectCardTemplate') as HTMLTemplateElement;
    const clone = template.content.cloneNode(true) as DocumentFragment;
    const card = clone.querySelector('.project-card') as HTMLElement;

    card.setAttribute('data-category', project.category);
    card.querySelector('.project-card__title')!.textContent = project.title;
    card.querySelector('.project-card__desc')!.textContent = project.description;
    card.querySelector('.project-card__year')!.textContent = project.year;
    card.querySelector('.project-card__category')!.textContent = CATEGORY_LABELS[project.category] ?? project.category;

    const linksEl = card.querySelector('.project-card__links')!;
    if (project.github) {
      const a = document.createElement('a');
      a.href = project.github; a.target = '_blank'; a.rel = 'noopener noreferrer';
      a.className = 'project-link'; a.setAttribute('aria-label', 'Ver en GitHub');
      a.innerHTML = GITHUB_ICON; linksEl.appendChild(a);
    }
    if (project.demo) {
      const a = document.createElement('a');
      a.href = project.demo; a.target = '_blank'; a.rel = 'noopener noreferrer';
      a.className = 'project-link'; a.setAttribute('aria-label', 'Ver demo');
      a.innerHTML = DEMO_ICON; linksEl.appendChild(a);
    }

    const tagsEl = card.querySelector('.project-card__tags')!;
    project.tags.forEach((tag) => {
      const span = document.createElement('span');
      span.className = 'tag'; span.textContent = tag;
      tagsEl.appendChild(span);
    });

    return card as HTMLElement;
  }

  async function loadProjects(): Promise<void> {
    const grid = document.getElementById('projectsGrid')!;
    const loading = document.getElementById('projectsLoading')!;
    const empty = document.getElementById('projectsEmpty')!;

    try {
      const res = await fetch('/data/projects.json');
      if (!res.ok) throw new Error('Error cargando proyectos');
      const projects: Project[] = await res.json();

      loading.style.display = 'none';

      const sorted = [...projects].sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0));
      sorted.forEach((project, i) => {
        const card = createProjectCard(project);
        card.style.transitionDelay = `${(i % 3) * 0.1}s`;
        grid.appendChild(card);
      });

      const observer = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.1 }
      );
      grid.querySelectorAll('.project-card').forEach(el => observer.observe(el));

    } catch (error) {
      loading.style.display = 'none';
      empty.classList.remove('hidden');
      empty.querySelector('p')!.textContent = 'Error cargando proyectos.';
      console.error(error);
    }
  }

  function setupFilters(): void {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const grid = document.getElementById('projectsGrid')!;
    const empty = document.getElementById('projectsEmpty')!;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('active');
        const filter = btn.dataset.filter!;
        const cards = grid.querySelectorAll<HTMLElement>('.project-card');
        let visibleCount = 0;
        cards.forEach((card) => {
          const match = filter === 'all' || card.dataset.category === filter;
          card.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });
        empty.classList.toggle('hidden', visibleCount > 0);
      });
    });
  }

  loadProjects().then(() => setupFilters());
</script>