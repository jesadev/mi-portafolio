---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="#hero" class="footer__logo">
        <span class="logo-bracket">&lt;</span>
        <span>TuNombre</span>
        <span class="logo-bracket"> /&gt;</span>
      </a>
      <p class="footer__tagline">Construyendo software con propósito.</p>
    </div>

    <nav class="footer__nav">
      <a href="#about">Sobre mí</a>
      <a href="#skills">Skills</a>
      <a href="#projects">Proyectos</a>
      <a href="#experience">Experiencia</a>
      <a href="#contact">Contacto</a>
    </nav>

    <div class="footer__bottom">
      <p class="footer__copy">
        © {year} Tu Nombre — Hecho con
        <a href="https://astro.build" target="_blank" rel="noopener" class="footer__astro-link">Astro</a>
        + ☕
      </p>
      <a href="#hero" class="footer__scroll-top" aria-label="Volver arriba">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="16" height="16">
          <path d="M18 15l-6-6-6 6"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border); padding-block: 3rem 2rem; background: var(--bg-secondary); }
  .footer__inner { display: flex; flex-direction: column; gap: 2rem; }
  .footer__brand { display: flex; flex-direction: column; gap: 0.4rem; }
  .footer__logo { font-family: var(--font-mono); font-size: 0.95rem; font-weight: 700; text-decoration: none; color: var(--text-primary); }
  .logo-bracket { color: var(--accent); }
  .footer__tagline { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted); max-width: none; }
  .footer__nav { display: flex; flex-wrap: wrap; gap: 1.5rem; padding-block: 1.25rem; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .footer__nav a { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-secondary); text-decoration: none; transition: color var(--transition-fast); }
  .footer__nav a:hover { color: var(--accent); }
  .footer__bottom { display: flex; align-items: center; justify-content: space-between; }
  .footer__copy { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); max-width: none; }
  .footer__astro-link { color: var(--accent-dim); text-decoration: none; }
  .footer__astro-link:hover { color: var(--accent); }
  .footer__scroll-top {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: var(--radius-sm);
    border: 1px solid var(--border-light); color: var(--text-muted);
    transition: all var(--transition-base); text-decoration: none;
  }
  .footer__scroll-top:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); transform: translateY(-2px); }
</style>