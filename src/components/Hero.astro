---
// src/components/Hero.astro
---

<section class="hero" id="hero">
  <!-- Animated grid background -->
  <div class="hero__grid" aria-hidden="true"></div>
  <!-- Glow orb -->
  <div class="hero__glow" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__content">
      <div class="hero__eyebrow">
        <span class="status-dot" aria-hidden="true"></span>
        <span class="hero__status">Disponible para nuevos proyectos</span>
      </div>

      <h1 class="hero__heading">
        <span class="hero__greeting">Hola, soy</span>
        <br />
        <span class="hero__name">Tu Nombre</span>
        <br />
        <em class="hero__role">Software Developer</em>
      </h1>

      <p class="hero__desc">
        Ingeniero de Software especializado en <strong>JavaScript moderno</strong>, 
        <strong>desarrollo backend con C#</strong> e integración de 
        <strong>inteligencia artificial</strong>. Construyo experiencias digitales 
        limpias, escalables y orientadas al impacto.
      </p>

      <div class="hero__actions">
        <a href="#projects" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 3h18v18H3z"/><path d="M3 9h18M9 9v12"/></svg>
          Ver proyectos
        </a>
        <a href="#contact" class="btn btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Contáctame
        </a>
        <a
          href="/cv-tu-nombre.pdf"
          class="btn btn-outline"
          download
          aria-label="Descargar CV"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          CV
        </a>
      </div>

      <div class="hero__links">
        <a href="https://github.com/tu-usuario" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://linkedin.com/in/tu-usuario" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <span class="divider-v" aria-hidden="true"></span>
        <a href="mailto:tu@email.com" class="social-link email-link">
          tu@email.com
        </a>
      </div>
    </div>

    <!-- Code decoration -->
    <div class="hero__code" aria-hidden="true">
      <div class="code-window">
        <div class="code-window__bar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="code-window__title">developer.js</span>
        </div>
        <pre class="code-window__body"><code><span class="c-comment">// Tu stack 2025</span>
<span class="c-keyword">const</span> <span class="c-var">developer</span> = <span class="c-punct">{'{' }</span>
  <span class="c-key">name</span><span class="c-punct">:</span> <span class="c-str">"Tu Nombre"</span><span class="c-punct">,</span>
  <span class="c-key">role</span><span class="c-punct">:</span> <span class="c-str">"Software Developer"</span><span class="c-punct">,</span>
  <span class="c-key">stack</span><span class="c-punct">:</span> <span class="c-punct">[</span>
    <span class="c-str">"JavaScript ES6+"</span><span class="c-punct">,</span>
    <span class="c-str">"C# / .NET"</span><span class="c-punct">,</span>
    <span class="c-str">"Astro"</span><span class="c-punct">,</span>
    <span class="c-str">"AI Integration"</span>
  <span class="c-punct">],</span>
  <span class="c-key">available</span><span class="c-punct">:</span> <span class="c-bool">true</span><span class="c-punct">,</span>
  <span class="c-key">passion</span><span class="c-punct">:</span> <span class="c-str">"clean code"</span>
<span class="c-punct">{'}'}</span><span class="c-punct">;</span>

<span class="c-comment">// Siempre aprendiendo 🚀</span></code></pre>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="scroll-label">scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 5rem;
    overflow: hidden;
  }

  /* Animated grid */
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
  }

  /* Glow */
  .hero__glow {
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--accent-glow-strong) 0%, transparent 70%);
    top: 10%;
    right: -10%;
    pointer-events: none;
    animation: float 8s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-30px) scale(1.05); }
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* Status */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px var(--accent-glow); }
    50%       { box-shadow: 0 0 0 6px rgba(184,255,53,0.05); }
  }

  .hero__status { color: var(--accent); }

  /* Heading */
  .hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    font-weight: 900;
    line-height: 1.08;
    margin-bottom: 1.5rem;
  }

  .hero__greeting {
    font-size: 0.45em;
    font-weight: 400;
    color: var(--text-secondary);
    display: block;
    margin-bottom: 0.25em;
  }

  .hero__name {
    color: var(--text-primary);
    display: block;
    letter-spacing: -0.03em;
  }

  .hero__role {
    font-style: italic;
    color: var(--accent);
    display: block;
  }

  .hero__desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 2rem;
    max-width: 52ch;
  }

  .hero__desc strong { color: var(--text-primary); font-weight: 500; }

  /* Actions */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  /* Social links */
  .hero__links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    transition: all var(--transition-base);
    border: 1px solid var(--border);
  }

  .social-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-glow);
    transform: translateY(-2px);
  }

  .email-link {
    width: auto;
    padding-inline: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .divider-v {
    width: 1px; height: 24px;
    background: var(--border-light);
    margin-inline: 0.5rem;
  }

  /* Code window */
  .hero__code { animation: float 10s ease-in-out infinite 2s; }

  .code-window {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow:
      0 32px 80px rgba(0,0,0,0.5),
      0 0 0 1px var(--border),
      inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .code-window__bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot.red    { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green  { background: #27c93f; }

  .code-window__title {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-left: auto;
  }

  .code-window__body {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.8;
    overflow-x: auto;
  }

  code { display: block; }

  .c-comment { color: #4a6478; }
  .c-keyword  { color: #c792ea; }
  .c-var      { color: #82aaff; }
  .c-key      { color: #89ddff; }
  .c-str      { color: var(--accent-dim); }
  .c-punct    { color: #89ddff; }
  .c-bool     { color: #ff9cac; }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50%       { opacity: 1; transform: scaleY(1.2); }
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero__code { order: -1; }
    .code-window__body { font-size: 0.75rem; }
  }

  @media (max-width: 480px) {
    .hero__actions { gap: 0.5rem; }
    .hero__glow { width: 300px; height: 300px; }
  }
</style>