---
// src/pages/index.astro
// Página principal — ensambla todos los componentes

import BaseLayout from '../layouts/Layout.astro';
import '../styles/global.css';

import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Tu Nombre | Software Developer"
  description="Ingeniero de Software especializado en JavaScript moderno, C# y desarrollo con IA. Construyo aplicaciones web limpias, escalables y orientadas al impacto."
>
  <Navbar />
  <main>
    <Hero />
    <About />
    <Skills />
    <Projects />
    <Experience />
    <Contact />
  </main>
  <Footer />
</BaseLayout>